#!/bin/bash

# ==========================================
# dynawall - Dynamic Wallpaper Engine for KDE
# ==========================================

# Terminal Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

# Configuration
WALL_DIR="$HOME/.local/share/dynawall"
mkdir -p "$WALL_DIR"

# Dependency Check
if ! command -v curl &> /dev/null; then
    echo -e "${RED}Error: curl is required.${NC}"
    exit 1
fi

if ! command -v plasma-apply-wallpaperimage &> /dev/null; then
    echo -e "${RED}Error: This script requires KDE Plasma 5.23 or newer.${NC}"
    exit 1
fi

update_wallpaper() {
    echo -e "${CYAN}Fetching real-time weather data...${NC}"
    
    # Get weather condition (e.g., "Clear", "Partly cloudy", "Rain")
    WEATHER=$(curl -s --max-time 5 "wttr.in/?format=%C" | tr '[:upper:]' '[:lower:]')
    
    if [[ -z "$WEATHER" || "$WEATHER" == *"unknown"* ]]; then
        echo -e "${YELLOW}Could not fetch weather. Defaulting to 'nature'.${NC}"
        WEATHER="nature"
    fi
    
    echo -e "Current local condition: ${BOLD}$WEATHER${NC}"

    # Map weather to image keywords
    case "$WEATHER" in
        *rain*|*drizzle*|*shower*) KEYWORD="rain,moody" ;;
        *snow*|*ice*|*blizzard*)   KEYWORD="snow,winter" ;;
        *cloud*|*overcast*)        KEYWORD="cloudy,sky" ;;
        *clear*|*sun*)             KEYWORD="sunny,landscape" ;;
        *fog*|*mist*)              KEYWORD="fog,forest" ;;
        *storm*|*thunder*)         KEYWORD="lightning,dark" ;;
        *)                         KEYWORD="landscape,nature" ;;
    esac

    IMG_PATH="$WALL_DIR/$KEYWORD.jpg"

    echo -e "${CYAN}Downloading image for keyword: ${BOLD}$KEYWORD${NC}..."
    # Fetch a random 1920x1080 image based on the keyword
    if curl -L -s --max-time 15 "https://loremflickr.com/1920/1080/$KEYWORD" -o "$IMG_PATH"; then
        echo -e "${CYAN}Applying to KDE Plasma...${NC}"
        plasma-apply-wallpaperimage "$IMG_PATH" > /dev/null
        echo -e "${GREEN}✔ Wallpaper updated successfully!${NC}"
    else
        echo -e "${RED}✖ Failed to download image.${NC}"
    fi
}

# Daemon Mode Logic
if [[ "$1" == "daemon" ]]; then
    echo -e "${GREEN}Starting Dynawall in Daemon mode... (Press Ctrl+C to stop)${NC}"
    while true; do
        update_wallpaper
        echo -e "${YELLOW}Sleeping for 60 minutes...${NC}"
        echo "---------------------------------------------------"
        sleep 3600 # Wait 1 hour (3600 seconds)
    done
else
    # Run once
    update_wallpaper
fi
